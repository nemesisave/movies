rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for auth state
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Admin role validation (bootstrapped with frankromero37@gmail.com and checking collection)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'frankromero37@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // User Validator Function (Anti-Update-Gap)
    function isValidUser(data) {
      return data.id is string &&
             data.email is string &&
             data.email.size() <= 200 &&
             (!('clubPoints' in data) || data.clubPoints is int) &&
             (!('triviaSolved' in data) || data.triviaSolved is bool) &&
             (!('favorites' in data) || data.favorites is list) &&
             (!('totebag' in data) || data.totebag is string);
    }

    // Match rules for application collections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clubPoints', 'triviaSolved', 'favorites', 'totebag'])
      );
      allow delete: if isAdmin();
    }

    // Video catalog validator
    function isValidVideo(data) {
      return data.id is string &&
             data.title_es is string && data.title_es.size() <= 200 &&
             data.title_en is string && data.title_en.size() <= 200 &&
             data.category is string && (data.category == 'movies' || data.category == 'series' || data.category == 'novelas' || data.category == 'sports' || data.category == 'kids') &&
             (!('isCustom' in data) || data.isCustom is bool) &&
             (!('status' in data) || data.status is string);
    }

    match /videos/{videoId} {
      allow read: if true; // Public catalog access
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    // Review validator
    function isValidReview(data) {
      return data.id is string &&
             data.video_id is string &&
             data.user_email is string &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 5000 &&
             data.date is string;
    }

    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isSignedIn() && isValidReview(request.resource.data) && (
        isAdmin() || request.resource.data.user_email == request.auth.token.email
      );
      allow update: if (isAdmin() || (isSignedIn() && resource.data.user_email == request.auth.token.email)) && isValidReview(request.resource.data);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.user_email == request.auth.token.email);
    }
  }
}
